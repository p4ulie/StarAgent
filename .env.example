# StarAgent configuration — copy to .env and fill in.
# .env is git-ignored. The ONLY real secret here is DISCORD_TOKEN.

# --- Discord (required) ---
# Bot token from https://discord.com/developers/applications -> your app -> Bot.
DISCORD_TOKEN=
# Optional: restrict slash-command sync to one guild for instant updates during dev.
DISCORD_GUILD_ID=

# --- LLM: your external llama.cpp server (OpenAI-compatible /v1 API) ---
# NOT part of the compose stack — run llama.cpp yourself and point here.
# From inside Docker, a server on the host is typically http://host.docker.internal:8080/v1
LLM_BASE_URL=http://host.docker.internal:8080/v1
# Model name to send to the server (llama.cpp usually ignores it, but LiteLlm requires one).
LLM_MODEL=llama.cpp
# Seconds before a single generation is abandoned.
LLM_TIMEOUT=120

# --- Embeddings (optional external server; see README "Faster ingestion") ---
# When set, embeddings are computed by an OpenAI-compatible /v1/embeddings
# endpoint (e.g. llama.cpp with an embedding GGUF) instead of local MiniLM.
# Switching embedders requires a fresh collection + full re-ingest!
#EMBEDDING_BASE_URL=http://host.docker.internal:8081/v1
#EMBEDDING_MODEL=nomic-embed-text

# --- ChromaDB (vector store) ---
# Service name on the compose network; use localhost when running the bot outside Docker.
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=star_citizen

# --- Ingestion ---
# Sent as the User-Agent on all scraper requests (RSI sits behind Cloudflare — identify yourself).
INGEST_USER_AGENT=StarAgent/0.1 (+https://github.com/p4ulie/StarAgent)
# Polite delay (seconds) between requests to the same source.
INGEST_RATE_DELAY=1.0

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8765

# --- Optional data-source keys ---
# UEX Corp application token (uexcorp.space -> My Apps). The uex_commodities
# source works without it; the token adds rate-limit headroom.
UEX_API_TOKEN=
# STARCITIZEN_API_KEY=
